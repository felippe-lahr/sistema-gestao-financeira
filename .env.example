# ============================================================
# VARIÁVEIS DE AMBIENTE - SISTEMA DE GESTÃO FINANCEIRA
# ============================================================
# Copie este arquivo para .env.local (desenvolvimento) ou
# configure as variáveis diretamente no Railway (produção/staging).
# NUNCA commite arquivos .env com valores reais no Git.
# ============================================================

# --- BANCO DE DADOS ---
# URL de conexão com o PostgreSQL (Railway fornece automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# --- AUTENTICAÇÃO ---
# Segredo para assinar os tokens JWT de sessão (mínimo 32 caracteres)
JWT_SECRET=seu_segredo_jwt_super_secreto_aqui

# --- SUPABASE STORAGE (para upload de arquivos) ---
# URL do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Chave anônima pública do Supabase (seguro expor no frontend)
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# --- APLICAÇÃO ---
# ID único da aplicação
VITE_APP_ID=sistema-gestao-financeira
# OpenID do usuário administrador (owner)
OWNER_OPEN_ID=admin@seudominio.com.br
# Ambiente (development | production)
NODE_ENV=development

# --- OAUTH (opcional) ---
# URL do servidor OAuth externo (deixe vazio para usar autenticação por email/senha)
OAUTH_SERVER_URL=

# --- RAILWAY / DEPLOY ---
# Porta do servidor (Railway define automaticamente)
PORT=3000
# Origens permitidas para CORS (separadas por vírgula)
ALLOWED_ORIGINS=https://seudominio.com.br,https://staging.seudominio.com.br
